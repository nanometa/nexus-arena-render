# Frontend
REACT_APP_GAME_SERVER_URL=http://localhost:8000
REACT_APP_GENESIS_PACK_ADDRESS=
REACT_APP_LITVM_RPC_URL=https://liteforge.rpc.caldera.xyz/http
REACT_APP_LITVM_CHAIN_ID=4441

# Multiplayer server CORS
CLIENT_ORIGIN=http://localhost:3001
CLIENT_ORIGINS=https://nexusarena.pro,https://www.nexusarena.pro

# HMAC secret for wallet sessions and match-seat identity tickets (32+ random characters).
# In production this is required; never expose it to the React frontend.
NEXUS_SESSION_SECRET=

# LitVM testnet
LITVM_RPC_URL=https://liteforge.rpc.caldera.xyz/http
LITVM_CHAIN_ID=4441
LITVM_WAIT_FOR_CONFIRMATION=false

# Deploy once with `npm run deploy:match-registry`, then put the printed address here.
MATCH_REGISTRY_ADDRESS=

# Server-side relayer wallet. Never expose this to the browser.
MATCH_REGISTRY_RELAYER_PRIVATE_KEY=

# Genesis pack contract. Deploy once with `npm run deploy:genesis-pack`, then copy the address.
GENESIS_PACK_ADDRESS=
GENESIS_PACK_BASE_URI=
GENESIS_PACK_DEPLOYER_PRIVATE_KEY=
PACK_CHAIN_STRICT=false

# Optional deployment/provider keys kept outside source control.
RENDER_API_KEY=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
